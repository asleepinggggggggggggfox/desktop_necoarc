DEEPSEEK_API_KEY=replace_with_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

XUNFEI_APP_ID=replace_with_xunfei_app_id
XUNFEI_API_KEY=replace_with_xunfei_api_key
XUNFEI_API_SECRET=replace_with_xunfei_api_secret
XUNFEI_IAT_URL=wss://iat-api.xfyun.cn/v2/iat
XUNFEI_LANGUAGE=zh_cn
XUNFEI_ACCENT=mandarin
SAMPLE_RATE=16000

CORS_ALLOW_ORIGINS=*

DASHSCOPE_API_KEY=replace_with_dashscope_key
DASHSCOPE_TTS_MODEL=cosyvoice-v3.5-plus
DASHSCOPE_TTS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
DASHSCOPE_TTS_V2_URL=wss://dashscope.aliyuncs.com/api-ws/v1/inference
DASHSCOPE_TTS_VOICE=cosyvoice-v3.5-plus-bailian-7aa8479594894dfca48fb4a6d57cf6bc
# qwen3 realtime 模型可使用 DASHSCOPE_TTS_INSTRUCTIONS。
# cosyvoice-v3.5-plus 使用 SSML 控制语速、音高、停顿。
