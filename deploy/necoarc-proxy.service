[Unit]
Description=Desktop Neco-Arc API Proxy
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/desktop_necoarc
EnvironmentFile=/etc/necoarc-proxy.env
ExecStart=/opt/desktop_necoarc/.venv/bin/uvicorn backend.proxy_server:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3
User=necoarc
Group=necoarc

[Install]
WantedBy=multi-user.target

